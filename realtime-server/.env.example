PORT=3001
HOST=0.0.0.0
# MySQL server default (VPS / XAMPP sering 3306)
DB_HOST=localhost
DB_PORT=3306
# MAMP (macOS): biasanya DB_HOST=127.0.0.1  DB_PORT=8889 — cek MAMP → Preferences → Ports
DB_USER=root
# MAMP default sering root — samakan dengan koneksi.php
DB_PASSWORD=root
DB_NAME=recepsionis_db
# Samakan dengan SOCKET_JWT_SECRET (config.socket.php) atau fallback dev di socket_token.php
JWT_SECRET=recepsionis-dev-jwt-secret-change-in-production
# Kosongkan untuk dev cepat, atau isi daftar origin yang diizinkan dipisah koma.
# Contoh: CORS_ORIGIN=http://127.0.0.1:8000,http://localhost:5173,http://192.168.1.10:8888
CORS_ORIGIN=
